# Example .env file for Travello Django Application
# Copy this file to `.env` and fill in the real values.
# DO NOT commit your real `.env` to public repos.

# ============================================================
# Environment & Debug Settings
# ============================================================
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# ============================================================
# Allowed Hosts
# ============================================================
ALLOWED_HOSTS=localhost,127.0.0.1,example.com

# ============================================================
# Database Configuration
# ============================================================
DB_ENGINE=django.db.backends.postgresql
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_NAME=travello

# ============================================================
# CORS Configuration
# ============================================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================
# Email Configuration
# ============================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@travello.com

# ============================================================
# Redis Configuration
# ============================================================
REDIS_URL=redis://127.0.0.1:6379/1

# ============================================================
# Celery Configuration
# ============================================================
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# ============================================================
# Sentry Configuration (Optional)
# ============================================================
SENTRY_DSN=

# ============================================================
# AWS/S3 Configuration (Optional)
# ============================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=

# ============================================================
# Application Settings
# ============================================================
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True



